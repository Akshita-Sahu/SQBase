<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>
    <extension-point id="org.jkiss.sqbase.dashboard" name="Dashboards" schema="schema/org.jkiss.sqbase.dashboard.exsd"/>

    <extension point="org.jkiss.sqbase.dashboard">
        <provider id="database"
                  class="org.jkiss.sqbase.model.dashboard.registry.DatabaseDashboardProvider"
                  label="Database"
                  description="Database dashboards"
                  icon="platform:/plugin/org.jkiss.sqbase.model/icons/tree/database.svg"
                  supportsCustomization="true"
                  databaseRequired="true"
                  defaultRenderer="timeseries"
                  dataType="timeseries"/>
        <provider id="web"
                  class="org.jkiss.sqbase.model.dashboard.registry.WebDashboardProvider"
                  label="Web"
                  description="Web dashboards"
                  icon="platform:/plugin/org.jkiss.sqbase.ui/icons/misc/browser.svg"
                  supportsCustomization="true"
                  defaultRenderer="browser"
                  dataType="provided"/>
    </extension>


    <extension point="org.eclipse.core.contenttype.contentTypes">
        <content-type
                base-type="org.eclipse.core.runtime.text"
                default-charset="utf-8"
                file-extensions="dashboard"
                id="org.jkiss.sqbase.dashboard"
                name="Dashboard"
                priority="normal"/>
    </extension>

    <extension point="org.jkiss.sqbase.resourceType">
        <type id="dashboard" name="Dashboard"
              icon="icons/dashboard.svg"
              folderIcon="icons/dashboard_folder.svg"
              managable="true">
            <root folder="Dashboards"/>
            <contentTypeBinding contentTypeId="org.jkiss.sqbase.dashboard"/>
        </type>
    </extension>

</plugin>
