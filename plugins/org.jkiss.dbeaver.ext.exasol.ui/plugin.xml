<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>

    <extension point="org.jkiss.sqbase.dataSourceView">
        <view
                id="org.jkiss.sqbase.ext.exasol.dataSourceWizardView"
                dataSource="exasol"
                targetID="org.jkiss.sqbase.ext.ui.newConnectionWizard"
                label="%dialog.connection.header"
                class="org.jkiss.sqbase.ext.exasol.ui.views.ExasolConnectionPage"
                icon="platform:/plugin/org.jkiss.sqbase.ext.exasol/icons/Exasol_icon.png">
        </view>
        <view
                id="org.jkiss.sqbase.ext.exasol.dataSourceEditorView"
                dataSource="exasol"
                targetID="org.jkiss.sqbase.ext.ui.editConnectionDialog"
                label="%dialog.connection.header"
                class="org.jkiss.sqbase.ext.exasol.ui.views.ExasolConnectionPage">
        </view>
    </extension>
    
    <extension point="org.eclipse.ui.editors">
        <editor
                name="%editor.org.jkiss.sqbase.ext.exasol.model.app.ExasolServerSessionEditor.name"
                icon="platform:/plugin/org.jkiss.sqbase.ext.exasol/icons/compile.png"
                class="org.jkiss.sqbase.ext.exasol.ui.editors.ExasolServerSessionEditor"
                id="org.jkiss.sqbase.ext.exasol.ui.editors.ExasolServerSessionEditor"
                contributorClass="org.jkiss.sqbase.ui.editors.EditorSearchActionsContributor">
        </editor>
        <editor
            name="%editor.org.jkiss.sqbase.ext.exasol.ui.editors.ExasolLockEditor.name"
            class="org.jkiss.sqbase.ext.exasol.ui.editors.ExasolLockEditor"
            icon="platform:/plugin/org.jkiss.sqbase.model/icons/tree/locked.svg"
            id="org.jkiss.sqbase.ext.exasol.ui.editors.ExasolLockEditor">
        </editor>

    </extension>
    
    <extension point="org.jkiss.sqbase.dataSourceProvider">
        <editorContribution editorId="org.jkiss.sqbase.ext.exasol.ui.editors.ExasolServerSessionEditor" category="connectionEditor" label="%editor.session_manager.name" icon="platform:/plugin/org.jkiss.sqbase.model/icons/tree/sessions.svg">
            <supports dataSource="exasol"/>
        </editorContribution>
        <editorContribution editorId="org.jkiss.sqbase.ext.exasol.ui.editors.ExasolLockEditor" category="connectionEditor" label="%editor.lock_manager.name" icon="#locked">
            <supports dataSource="exasol"/>
        </editorContribution>
    </extension>
    
	<extension point="org.jkiss.sqbase.databaseEditor">    
	    <editor
	              class="org.jkiss.sqbase.ext.exasol.ui.editors.ExasolSourceViewEditor"
	              contributor="org.jkiss.sqbase.ui.editors.sql.SQLEditorContributorNested"
	              description="%editor.exasol.source.view.description"
	              icon="#sql_text"
	              id="exasol.source.view"
	              label="%editor.exasol.source.view.label"
	              position="additions_middle"
	              type="folder">
	           <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolView"/>
	           <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolScript"/>
	           <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolFunction"/>
	    </editor>
        <editor
                class="org.jkiss.sqbase.ui.editors.sql.SQLSourceViewer"
                contributor="org.jkiss.sqbase.ui.editors.sql.SQLEditorContributorNested"
                description="%editor.source.ddl.description"
                icon="#sql_text"
                id="source.ddl"
                label="%editor.source.ddl.name"
                position="additions_middle"
                type="folder">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolTable"/>
        </editor>
        <editor
                class="org.jkiss.sqbase.ui.editors.sql.SQLSourceViewer"
                contributor="org.jkiss.sqbase.ui.editors.sql.SQLEditorContributorNested"
                description="%editor.source.declaration.description"
                embeddable="true"
                icon="#sql_text"
                id="source.declaration"
                label="%meta.org.jkiss.sqbase.ext.exasol.model.ExasolVirtualSchema.adapterNotes.name"
                position="additions_middle"
                type="folder">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolVirtualSchema"/>
        </editor>
        
        <configurator class="org.jkiss.sqbase.ext.exasol.ui.config.ExasolConsumerGroupConfigurator">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolConsumerGroup"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.exasol.ui.config.ExasolForeignKeyConfigurator">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolTableForeignKey"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.exasol.ui.config.ExasolSchemaConfigurator">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolSchema"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.exasol.ui.config.ExasolConnectionConfigurator">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolConnection"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.exasol.ui.config.ExasolUserConfigurator">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.security.ExasolUser"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.exasol.ui.config.ExasolPriorityGroupConfigurator">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolPriorityGroup"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.exasol.ui.config.ExasolPrimaryKeyConfigurator">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolTableUniqueKey"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.exasol.ui.config.ExasolRoleConfigurator">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.security.ExasolRole"/>
        </configurator>   
        <configurator class="org.jkiss.sqbase.ext.exasol.ui.config.ExasolIndexConfigurator">
            <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolTableIndex"/>
        </configurator>              
    </extension>
    
    <extension point="org.jkiss.sqbase.tools">
      <tools>
         <tool
               description="%tool.org.jkiss.sqbase.ext.exasol.table.export.description"
               id="org.jkiss.sqbase.ext.exasol.ui.tools.ExasolExportTableTool"
               label="%tool.org.jkiss.sqbase.ext.exasol.table.export.name">
             <command id="org.jkiss.sqbase.ext.exasol.ui.exportTable">
                 <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolTable"/>
                 <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolView"/>
                 <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolSchema"/>
             </command>
         </tool>
         <tool
               description="%tool.org.jkiss.sqbase.ext.exasol.table.import.description"
               id="org.jkiss.sqbase.ext.exasol.ui.tools.ExasolImportTableTool"
               label="%tool.org.jkiss.sqbase.ext.exasol.table.import.name">
             <command id="org.jkiss.sqbase.ext.exasol.ui.importTable">
                 <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolSchema"/>
                 <objectType name="org.jkiss.sqbase.ext.exasol.model.ExasolTable"/>
             </command>
         </tool>

          <tool
               description="Truncate table(s)"
               id="org.jkiss.sqbase.ext.exasol.ui.tools.ExasolToolTruncate"
               group="org.jkiss.sqbase.ext.exasol.ui.tools"
               label="Truncate"
               singleton="false">
              <task id="exasolToolTruncateTable"/>
          </tool>
      </tools>
    </extension>

    <extension point="org.eclipse.ui.commands">
        <command id="org.jkiss.sqbase.ext.exasol.ui.exportTable" name="%tool.org.jkiss.sqbase.ext.exasol.table.export.name"/>
        <command id="org.jkiss.sqbase.ext.exasol.ui.importTable" name="%tool.org.jkiss.sqbase.ext.exasol.table.import.name"/>
    </extension>

    <extension point="org.eclipse.ui.handlers">
        <handler commandId="org.jkiss.sqbase.ext.exasol.ui.exportTable" class="org.jkiss.sqbase.ext.exasol.ui.tools.ExasolExportTableToolCommandHandler"/>
        <handler commandId="org.jkiss.sqbase.ext.exasol.ui.importTable" class="org.jkiss.sqbase.ext.exasol.ui.tools.ExasolImportTableToolCommandHandler"/>
    </extension>

</plugin>
