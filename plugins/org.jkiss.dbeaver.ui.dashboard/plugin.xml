<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>

    <extension-point id="org.jkiss.sqbase.dashboard.ui" name="Dashboards UI" schema="schema/org.jkiss.sqbase.dashboard.ui.exsd"/>

    <extension point="org.eclipse.ui.views">
        <view
                id="org.jkiss.sqbase.ui.dashboardView"
                category="org.jkiss.sqbase.core.category"
                class="org.jkiss.sqbase.ui.dashboard.view.DataSourceDashboardView"
                allowMultiple="true"
                icon="platform:/plugin/org.jkiss.sqbase.model.dashboard/icons/dashboard.svg"
                name="%view.dashboard.title"/>
    </extension>

    <extension point="org.eclipse.ui.editors">
        <editor
                name="%editor.dashboard.name"
                icon="platform:/plugin/org.jkiss.sqbase.model.dashboard/icons/dashboard.svg"
                class="org.jkiss.sqbase.ui.dashboard.editor.DashboardEditorStandalone"
                id="org.jkiss.sqbase.ui.dashboard.editor.DashboardEditorStandalone">
        </editor>
    </extension>

    <!-- Hide dashboard view from Show View menu -->
    <extension point="org.eclipse.ui.activities">
        <activity id="org.jkiss.sqbase.dashboard.view" name="Dashboard view hide"/>
        <activityPatternBinding activityId="org.jkiss.sqbase.dashboard.view" isEqualityPattern="true" pattern="org.jkiss.sqbase.ui.dashboard/org.jkiss.sqbase.ui.dashboardView"/>
    </extension>

    <extension point="org.eclipse.ui.commands">
        <command id="org.jkiss.sqbase.ui.dashboard.open" name="%command.org.jkiss.sqbase.ui.dashboard.open.name" description="%command.org.jkiss.sqbase.ui.dashboard.open.description" categoryId="org.jkiss.sqbase.core.database"/>
        <command id="org.jkiss.sqbase.ui.dashboard.configure" name="%command.org.jkiss.sqbase.ui.dashboard.configure.name" description="%command.org.jkiss.sqbase.ui.dashboard.configure.description" categoryId="org.jkiss.sqbase.core.database"/>
        <command id="org.jkiss.sqbase.ui.chart.refresh" name="%command.org.jkiss.sqbase.ui.chart.refresh.name" description="%command.org.jkiss.sqbase.ui.chart.refresh.description" categoryId="org.jkiss.sqbase.core.database"/>

        <command id="org.jkiss.sqbase.ui.dashboard.create" name="%command.org.jkiss.sqbase.ui.dashboard.create.name" description="%command.org.jkiss.sqbase.ui.dashboard.create.description" categoryId="org.jkiss.sqbase.core.database">
            <commandParameter id="datasource" name="Create dashboard for active datasource" optional="true"/>
        </command>
        <command id="org.jkiss.sqbase.ui.dashboard.delete" name="%command.org.jkiss.sqbase.ui.dashboard.delete.name" description="%command.org.jkiss.sqbase.ui.dashboard.delete.description" categoryId="org.jkiss.sqbase.core.database"/>
        <command id="org.jkiss.sqbase.ui.dashboard.add" name="%command.org.jkiss.sqbase.ui.dashboard.add.name" description="%command.org.jkiss.sqbase.ui.dashboard.add.description" categoryId="org.jkiss.sqbase.core.database">
        </command>
         <command id="org.jkiss.sqbase.ui.dashboard.catalog.show" name="%command.org.jkiss.sqbase.ui.dashboard.catalog.show.name" description="%command.org.jkiss.sqbase.ui.dashboard.catalog.show.description" categoryId="org.jkiss.sqbase.core.database">
            <commandParameter id="toggleCatalogPanel" name="%command.org.jkiss.sqbase.ui.dashboard.catalog.show.name" optional="true"/>
        </command>
        <command id="org.jkiss.sqbase.ui.dashboard.remove" name="%command.org.jkiss.sqbase.ui.dashboard.remove.name" description="%command.org.jkiss.sqbase.ui.dashboard.remove.description" categoryId="org.jkiss.sqbase.core.database"/>
        <command id="org.jkiss.sqbase.ui.dashboard.view" name="%command.org.jkiss.sqbase.ui.dashboard.view.name" description="%command.org.jkiss.sqbase.ui.dashboard.view.description" categoryId="org.jkiss.sqbase.core.database"/>
    </extension>

    <extension point="org.eclipse.ui.commandImages">
        <image commandId="org.jkiss.sqbase.ui.dashboard.open" icon="platform:/plugin/org.jkiss.sqbase.model.dashboard/icons/dashboard.svg"/>
        <image commandId="org.jkiss.sqbase.ui.dashboard.catalog.show" icon="platform:/plugin/org.jkiss.sqbase.ui/icons/misc/config_table.svg"/>
        <image commandId="org.jkiss.sqbase.ui.dashboard.delete" icon="platform:/plugin/org.jkiss.sqbase.ui/icons/delete.svg"/>
        <image commandId="org.jkiss.sqbase.ui.dashboard.configure" icon="platform:/plugin/org.jkiss.sqbase.ui/icons/configuration.svg"/>
    </extension>

    <extension point="org.eclipse.ui.handlers">
        <!-- Dashboard handlers -->

        <handler commandId="org.jkiss.sqbase.ui.dashboard.open" class="org.jkiss.sqbase.ui.dashboard.navigator.HandlerDashboardOpen">
        </handler>
        <handler commandId="org.jkiss.sqbase.ui.dashboard.create" class="org.jkiss.sqbase.ui.dashboard.navigator.HandlerDashboardCreate">
            <enabledWhen>
                <test property="org.jkiss.sqbase.core.global.ui.hasPermission" value="database-developer"/>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.ui.dashboard.delete" class="org.jkiss.sqbase.ui.dashboard.navigator.HandlerDashboardDelete">
            <enabledWhen>
                <test property="org.jkiss.sqbase.core.global.ui.hasPermission" value="database-developer"/>
            </enabledWhen>
        </handler>

        <handler commandId="org.jkiss.sqbase.ui.dashboard.configure" class="org.jkiss.sqbase.ui.dashboard.navigator.HandlerDashboardConfiguration">
            <enabledWhen>
                <test property="org.jkiss.sqbase.core.global.ui.hasPermission" value="database-developer"/>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.ui.chart.refresh" class="org.jkiss.sqbase.ui.dashboard.navigator.HandlerDashboardResetItem">
            <enabledWhen>
                <test property="org.jkiss.sqbase.core.global.ui.hasPermission" value="configuration-manager"/>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.ui.dashboard.add" class="org.jkiss.sqbase.ui.dashboard.navigator.HandlerDashboardAddItem">
            <enabledWhen>
                <test property="org.jkiss.sqbase.core.global.ui.hasPermission" value="configuration-manager"/>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.ui.dashboard.catalog.show" class="org.jkiss.sqbase.ui.dashboard.navigator.HandlerDashboardShowCatalog">
            <enabledWhen>
                <test property="org.jkiss.sqbase.core.global.ui.hasPermission" value="configuration-manager"/>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.ui.dashboard.remove" class="org.jkiss.sqbase.ui.dashboard.navigator.HandlerDashboardRemoveItem">
            <enabledWhen>
                <and>
                    <test property="org.jkiss.sqbase.core.global.ui.hasPermission" value="configuration-manager"/>
                </and>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.ui.dashboard.view" class="org.jkiss.sqbase.ui.dashboard.navigator.HandlerDashboardViewItem">
        </handler>
    </extension>

    <extension point="org.eclipse.ui.menus">

        <menuContribution allPopups="false" locationURI="toolbar:sqbase-tools?after=additions">
            <separator name="dashboard" visible="true"/>
            <command commandId="org.jkiss.sqbase.ui.dashboard.open" style="pulldown" id="org.jkiss.sqbase.menu.dashboards">
                <visibleWhen>
                    <and>
                        <test property="org.jkiss.sqbase.core.global.ui.hasPermission" value="database-developer"/>
                        <reference definitionId="SQBasePerspectiveActive"/>
                    </and>
                </visibleWhen>
            </command>
        </menuContribution>

        <menuContribution allPopups="false" locationURI="menu:dataSourceMenu?after=tools">
            <command commandId="org.jkiss.sqbase.ui.dashboard.open">
                <visibleWhen checkEnabled="true"><test property="org.jkiss.sqbase.core.global.ui.hasPermission" value="database-developer"/></visibleWhen>
            </command>
        </menuContribution>

        <menuContribution allPopups="false" locationURI="toolbar:org.jkiss.sqbase.ui.dashboardView">
            <command commandId="org.jkiss.sqbase.ui.dashboard.add" icon="platform:/plugin/org.jkiss.sqbase.ui/icons/chart/chart_line.svg">
                <visibleWhen checkEnabled="true"/>
            </command>
            <command commandId="org.jkiss.sqbase.ui.dashboard.catalog.show" icon="platform:/plugin/org.jkiss.sqbase.ui/icons/misc/config_table.svg">
                <parameter name="toggleCatalogPanel" value="true"/>
                <visibleWhen checkEnabled="true"/>
            </command>
            <command commandId="org.jkiss.sqbase.ui.dashboard.configure">
                <visibleWhen checkEnabled="true"/>
            </command>
            <separator name="additions" visible="true"/>
            <command commandId="org.jkiss.sqbase.ui.dashboard.delete">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>

        <menuContribution locationURI="menu:org.jkiss.sqbase.menu.dashboards">
            <dynamic id="org.jkiss.sqbase.menu.dashboards.pulldown" class="org.jkiss.sqbase.ui.dashboard.navigator.DashboardDynamicMenuContributor"/>
            <separator name="additions" visible="true"/>
        </menuContribution>

        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=create">
            <command commandId="org.jkiss.sqbase.ui.dashboard.create">
                <visibleWhen checkEnabled="true">
                    <with variable="selection">
                        <count value="1"/>
                        <iterate operator="and">
                            <adapt type="org.eclipse.core.resources.IFolder">
                                <and>
                                    <test property="org.jkiss.sqbase.core.resource.type" value="dashboard folder"/>
                                    <test property="org.jkiss.sqbase.core.global.ui.currentProjectResourceEditable"/>
                                </and>
                            </adapt>
                        </iterate>
                    </with>
                </visibleWhen>
            </command>
        </menuContribution>
    </extension>

    <extension point="org.jkiss.sqbase.tools">
        <tools>
            <tool id="org.jkiss.sqbase.ui.dashboard.view.DashboardOpenTool"
                  label="%command.org.jkiss.sqbase.ui.dashboard.open.name"
                  description="%command.org.jkiss.sqbase.ui.dashboard.open.description"
                  icon="platform:/plugin/org.jkiss.sqbase.model.dashboard/icons/dashboard.svg"
                  singleton="false">
                <command id="org.jkiss.sqbase.ui.dashboard.open">
                    <objectType name="org.jkiss.sqbase.model.DBPDataSource"/>
                </command>
            </tool>
        </tools>
    </extension>

    <extension point="org.eclipse.ui.bindings">
        <key commandId="org.jkiss.sqbase.ui.dashboard.open" contextId="org.jkiss.sqbase.ui.perspective" schemeId="org.eclipse.ui.defaultAcceleratorConfiguration" sequence="CTRL+ALT+SHIFT+B"/>
    </extension>

    <extension point="org.jkiss.sqbase.resourceHandler">
        <handler type="dashboard" class="org.jkiss.sqbase.ui.dashboard.navigator.DashboardResourceHandler"/>
    </extension>

    <extension point="org.eclipse.core.runtime.preferences">
        <initializer class="org.jkiss.sqbase.ui.dashboard.internal.UIDashboardPreferencesInitializer"/>
    </extension>

    <extension point="org.jkiss.sqbase.dashboard.ui">
        <dashboardView id="timeseries" label="Time series" icon="platform:/plugin/org.jkiss.sqbase.ui/icons/chart/chart_line.svg"
            dataTypes="timeseries" native="true"
            renderer="org.jkiss.sqbase.ui.dashboard.histogram.DashboardRendererTimeseries"
            configurationEditor="org.jkiss.sqbase.ui.dashboard.control.DatabaseChartConfigurationEditor"
            viewSettingsEditor="org.jkiss.sqbase.ui.dashboard.control.DatabaseChartViewSettingsEditor">

        </dashboardView>
        <dashboardView id="browser" label="Browser" icon="platform:/plugin/org.jkiss.sqbase.ui/icons/misc/browser.svg"
            dataTypes="provided"
            renderer="org.jkiss.sqbase.ui.dashboard.browser.DashboardRendererBrowser"
            configurationEditor="org.jkiss.sqbase.ui.dashboard.browser.BrowserChartConfigurationEditor"
            viewSettingsEditor="org.jkiss.sqbase.ui.dashboard.browser.BrowserChartViewSettingsEditor">

        </dashboardView>
    </extension>

    <extension point="org.eclipse.ui.newWizards">
        <wizard
                category="org.jkiss.sqbase.core.new.general"
                class="org.jkiss.sqbase.ui.dashboard.navigator.DashboardCreateWizard"
                icon="platform:/plugin/org.jkiss.sqbase.model.dashboard/icons/dashboard.svg"
                id="org.jkiss.sqbase.ui.dashboard.navigator.DashboardCreateWizard"
                name="%wizard.dashboard.name">
            <description>
                %wizard.dashboard.description
            </description>
        </wizard>
    </extension>

    <extension point="org.eclipse.ui.perspectiveExtensions">
        <perspectiveExtension targetID="org.jkiss.sqbase.core.perspective">
            <newWizardShortcut id="org.jkiss.sqbase.ui.dashboard.navigator.DashboardCreateWizard"/>
        </perspectiveExtension>
    </extension>

</plugin>
