<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

    <extension point="org.jkiss.sqbase.expressions">
        <namespace id="geo" class="org.jkiss.sqbase.model.gis.GisExpressionFunctions" description="GIS functions"/>
    </extension>

    <extension point="org.jkiss.sqbase.dataTypeProvider">
        <!-- Spatial transformer -->
        <transformer
            class="org.jkiss.sqbase.data.gis.handlers.GeometryAttributeTransformer"
            id="GeometryAttributeTransformer"
            name="%transformer.org.jkiss.sqbase.data.gis.handlers.GeometryAttributeTransformer.name"
            description="%transformer.org.jkiss.sqbase.data.gis.handlers.GeometryAttributeTransformer.description"
            applyByDefault="false"
            custom="true">
            <type kind="STRING"/>
            <type kind="BINARY"/>
            <propertyGroup label="%property-group.org.jkiss.sqbase.dataTypeProvider.label">
                <property id="srid" label="SRID" type="string" description="%property-group.org.jkiss.sqbase.dataTypeProvider.srid.description" defaultValue="4326" required="false" validValues=""/>
                <property id="invertCoordinates" label="%property-group.org.jkiss.sqbase.dataTypeProvider.invertCoordinates.label" type="boolean" description="%property-group.org.jkiss.sqbase.dataTypeProvider.invertCoordinates.description" defaultValue="false" required="false"/>
                <property id="leadingSrid" label="%property-group.org.jkiss.sqbase.dataTypeProvider.leadingSrid.label" type="boolean" description="%property-group.org.jkiss.sqbase.dataTypeProvider.leadingSrid.description" defaultValue="false" required="false"/>
            </propertyGroup>
        </transformer>

    </extension>

    <extension point="org.jkiss.sqbase.dataHintProvider">
        <hintProvider id="gis-srid" for="cell" class="org.jkiss.sqbase.model.gis.hints.GisCellHintProvider" label="%hints.gis-srid.label" description="%hints.gis-srid.description" visibleByDefault="false">
            <supports type="org.jkiss.sqbase.model.gis.DBGeometry"/>
        </hintProvider>
    </extension>

</plugin>
