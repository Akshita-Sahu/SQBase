<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>

    <extension point="org.jkiss.sqbase.dataManager">
        <manager class="org.jkiss.sqbase.ext.sqlite.ui.data.manager.SQLiteValueManager" id="org.jkiss.sqbase.ext.sqlite.ui.data.manager.SQLiteValueManager">
            <supports dataSource="org.jkiss.sqbase.ext.sqlite.model.SQLiteDataSource"/>
        </manager>
    </extension>

    <extension point="org.jkiss.sqbase.fileTypeHandler">
        <handler id="sqlite" class="org.jkiss.sqbase.ext.sqlite.ui.SQLiteFileDatabaseHandler" remote="false" order="101">
            <extension id="sqlite" extensions="db,sdb,sqlite,db3,s3db,sqlite3,sl3,db2,s2db,sqlite2,sl2" icon="platform:/plugin/org.jkiss.sqbase.ext.sqlite/icons/sqlite_icon_big.png"/>
        </handler>
    </extension>

    <extension point="org.jkiss.sqbase.ui.propertyConfigurator">
        <propertyConfigurator class="org.jkiss.sqbase.ext.sqlite.auth.LibSQLAuthModelToken"
                              uiClass="org.jkiss.sqbase.ext.sqlite.ui.config.LibSQLTokenAuthModelConfigurator"/>
    </extension>

</plugin>
