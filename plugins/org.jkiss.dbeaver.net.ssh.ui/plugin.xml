<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>

    <extension point="org.jkiss.sqbase.ui.propertyConfigurator">
        <propertyConfigurator class="org.jkiss.sqbase.model.net.ssh.SSHTunnelImpl" uiClass="org.jkiss.sqbase.ui.net.ssh.SSHTunnelConfiguratorUI"/>
    </extension>

    <extension point="org.eclipse.core.runtime.adapters">
        <factory adaptableType="org.jkiss.sqbase.model.net.ssh.JSCHSessionController" class="org.jkiss.sqbase.ui.net.ssh.jsch.JSCHUIPromptProviderAdapterFactory">
            <adapter type="org.jkiss.sqbase.model.net.ssh.JSCHUserInfoPromptProvider"/>
        </factory>
    </extension>

    <extension point="org.eclipse.ui.views">
        <view
            id="com.sqbase.ssh.tunnels"
            category="org.jkiss.sqbase.core.category"
            class="org.jkiss.sqbase.ui.net.ssh.SSHTunnelView"
            icon="platform:/plugin/org.jkiss.sqbase.ui/icons/sql/connect.svg"
            name="SSH tunnel explorer">
            <description>SSH tunnel explorer. Allows to view and manage SSH tunnels.</description>
        </view>
    </extension>

</plugin>
