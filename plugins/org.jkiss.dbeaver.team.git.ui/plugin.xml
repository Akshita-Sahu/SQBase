<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>

    <extension point="org.eclipse.ui.commands">
        <category id="org.jkiss.sqbase.git.commands.category" name="Git Category"/>
        <command categoryId="org.jkiss.sqbase.git.commands.category" id="org.jkiss.sqbase.git.commands.share" name="%command.org.jkiss.sqbase.git.commands.share.name"/>
        <command categoryId="org.jkiss.sqbase.git.commands.category" id="org.jkiss.sqbase.git.commands.projectFromGit" name="%command.org.jkiss.sqbase.git.commands.projectFromGit.name"/>
        <command categoryId="org.jkiss.sqbase.git.commands.category" id="org.jkiss.sqbase.git.commands.commit" name="%command.org.jkiss.sqbase.git.commands.commit.name"/>
        <command categoryId="org.jkiss.sqbase.git.commands.category" id="org.jkiss.sqbase.git.commands.update" name="%command.org.jkiss.sqbase.git.commands.update.name"/>
        <command categoryId="org.jkiss.sqbase.git.commands.category" id="org.jkiss.sqbase.git.commands.showHistory" name="%command.org.jkiss.sqbase.git.commands.showHistory.name"/>
    </extension>
    <extension point="org.eclipse.ui.commandImages">
        <image commandId="org.jkiss.sqbase.git.commands.share" icon="icons/share.png"/>
        <image commandId="org.jkiss.sqbase.git.commands.projectFromGit" icon="icons/clone.svg"/>

        <image commandId="org.jkiss.sqbase.git.commands.update" icon="icons/pull.svg"/>
        <image commandId="org.jkiss.sqbase.git.commands.commit" icon="icons/push.svg"/>
    </extension>

    <extension point="org.eclipse.core.expressions.propertyTesters">
        <propertyTester
                class="org.jkiss.sqbase.team.git.ui.handlers.GitPropertyTester"
                id="org.jkiss.sqbase.team.git.ui.handlers.GitPropertyTester"
                namespace="org.jkiss.sqbase.team.git"
                properties="canShare,canCommit,canUpdate"
                type="org.eclipse.core.resources.IResource">
        </propertyTester>
    </extension>

    <extension point="org.eclipse.ui.handlers">
        <handler commandId="org.jkiss.sqbase.git.commands.share" class="org.jkiss.sqbase.team.git.ui.handlers.ProjectShareHandler">
            <activeWhen>
                <not>
                    <test property="GitSelection.projectsSingleRepository" />
                </not>
            </activeWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.git.commands.projectFromGit" class="org.jkiss.sqbase.team.git.ui.handlers.ProjectCloneHandler">
            <enabledWhen>
                <test property="org.jkiss.sqbase.core.global.ui.canCreateProject"/>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.git.commands.update" class="org.jkiss.sqbase.team.git.ui.handlers.GITUpdateHandler">
            <activeWhen>
                <test property="GitSelection.resourcesSingleRepository"/>
            </activeWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.git.commands.commit" class="org.jkiss.sqbase.team.git.ui.handlers.GITCommitHandler">
            <activeWhen>
                <test property="GitSelection.resourcesSingleRepository"/>
            </activeWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.git.commands.showHistory" class="org.jkiss.sqbase.team.git.ui.handlers.GITHistoryHandler">
        </handler>
    </extension>

    <extension point="org.eclipse.ui.bindings">
        <key commandId="org.jkiss.sqbase.git.commands.update" schemeId="org.jkiss.sqbase.defaultKeyScheme" sequence="CTRL+SHIFT+U"/>
        <key commandId="org.jkiss.sqbase.git.commands.commit" schemeId="org.jkiss.sqbase.defaultKeyScheme" sequence="CTRL+SHIFT+K"/>
    </extension>

    <extension point="org.eclipse.ui.menus">
        <menuContribution locationURI="menu:file?before=properties">
            <separator name="git" visible="true"/>
            <menu id="org.jkiss.sqbase.team.git.menu" label="Git" mnemonic="M">
                <visibleWhen><reference definitionId="SQBasePerspectiveActive"/></visibleWhen>
                <command commandId="org.jkiss.sqbase.git.commands.update" mnemonic="L"/>
                <command commandId="org.jkiss.sqbase.git.commands.commit" mnemonic="C"/>
                <separator name="projects" visible="true"/>
                <command commandId="org.jkiss.sqbase.git.commands.share" mnemonic="G"/>
                <command commandId="org.jkiss.sqbase.git.commands.projectFromGit" mnemonic="G"/>
                <separator name="view" visible="true"/>
                <command commandId="org.jkiss.sqbase.core.view.toggle" style="toggle"><parameter name="viewId" value="org.eclipse.egit.ui.RepositoriesView"/></command>
            </menu>
        </menuContribution>

        <menuContribution locationURI="menu:org.jkiss.sqbase.menu.git">
            <command commandId="org.jkiss.sqbase.git.commands.update" mnemonic="L">
                <visibleWhen><reference definitionId="SQBasePerspectiveActive"/></visibleWhen>
            </command>
            <command commandId="org.jkiss.sqbase.git.commands.commit" mnemonic="C">
                <visibleWhen><reference definitionId="SQBasePerspectiveActive"/></visibleWhen>
            </command>
            <separator name="share" visible="true"/>
            <command commandId="org.jkiss.sqbase.git.commands.share" mnemonic="G">
                <visibleWhen><reference definitionId="SQBasePerspectiveActive"/></visibleWhen>
            </command>
            <separator name="view" visible="true"/>
            <command commandId="org.jkiss.sqbase.core.view.toggle" style="toggle"><parameter name="viewId" value="org.eclipse.egit.ui.RepositoriesView"/></command>
        </menuContribution>

        <menuContribution allPopups="false" locationURI="toolbar:sqbase-tools?after=additions">
            <separator name="git" visible="false"/>
            <command commandId="org.jkiss.sqbase.git.commands.showHistory" icon="icons/clone.svg" label="Git" style="pulldown" id="org.jkiss.sqbase.menu.git">
                <visibleWhen><reference definitionId="SQBasePerspectiveActive"/></visibleWhen>
            </command>
        </menuContribution>

        <menuContribution allPopups="false" locationURI="toolbar:org.jkiss.sqbase.core.projectNavigator?before=additions">
            <command commandId="org.jkiss.sqbase.git.commands.projectFromGit">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <menuContribution allPopups="false" locationURI="menu:org.jkiss.sqbase.core.projectNavigator?before=additions">
            <command commandId="org.jkiss.sqbase.git.commands.projectFromGit">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>

    </extension>

    <extension point="org.jkiss.sqbase.notifications">
        <notification id="git.project.added" name="Project was added to Git"/>
    </extension>

</plugin>
