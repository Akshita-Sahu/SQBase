<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>

    <!-- Deprecated extension point, must be replaced with tasks UI configurators -->
    <extension-point id="org.jkiss.sqbase.tools" name="%extension-point.org.jkiss.sqbase.tools.name" schema="schema/org.jkiss.sqbase.tools.exsd"/>
    <extension-point id="org.jkiss.sqbase.task.ui" name="%extension-point.org.jkiss.sqbase.task.ui.name" schema="schema/org.jkiss.sqbase.task.ui.exsd"/>

    <extension point="org.jkiss.sqbase.clearHistoryHandler">
        <handler
                id="taskRunHistory"
                name="%handler.taskRunHistory.name"
                description="%handler.taskRunHistory.description"
                handler="org.jkiss.sqbase.tasks.ui.handlers.TaskClearHistoryHandler"/>
    </extension>

    <extension point="org.jkiss.sqbase.notifications">
        <notification id="task.execute.success" name="Task execution success" soundEnabled="true"/>
        <notification id="task.execute.failure" name="Task execution failure" soundEnabled="true"/>
    </extension>

</plugin>
