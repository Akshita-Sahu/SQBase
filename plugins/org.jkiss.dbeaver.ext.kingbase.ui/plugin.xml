<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>

<plugin>
    <extension point="org.jkiss.sqbase.dataSourceView">
    <view id="org.jkiss.sqbase.ext.postgresql.dataSourceWizardView" dataSource="kingbase" targetID="org.jkiss.sqbase.ext.ui.newConnectionWizard" label="%dialog.connection.header" class="org.jkiss.sqbase.ext.kingbase.ui.views.KingbaseConnectionPage" icon="platform:/plugin/org.jkiss.sqbase.ext.kingbase/icons/kingbase_icon.png"/>
    <view id="org.jkiss.sqbase.ext.postgresql.dataSourceEditorView" dataSource="kingbase" targetID="org.jkiss.sqbase.ext.ui.editConnectionDialog" label="%dialog.connection.header" class="org.jkiss.sqbase.ext.kingbase.ui.views.KingbaseConnectionPage" icon="platform:/plugin/org.jkiss.sqbase.ext.kingbase/icons/kingbase_icon.png"/>
  </extension>
  <extension point="org.jkiss.sqbase.databaseEditor">
    
    <configurator class="org.jkiss.sqbase.ext.kingbase.ui.config.KingbaseDatabaseConfigurator">
      <objectType name="org.jkiss.sqbase.ext.kingbase.model.KingbaseDatabase"/>
    </configurator>
   
    <configurator class="org.jkiss.sqbase.ext.kingbase.ui.config.KingbaseProcedureConfigurator">
      <objectType name="org.jkiss.sqbase.ext.kingbase.model.KingbaseProcedure"/>
    </configurator>
    <configurator class="org.jkiss.sqbase.ext.kingbase.ui.config.KingbaseFunctionConfigurator">
      <objectType name="org.jkiss.sqbase.ext.kingbase.model.KingbaseFunction"/>
    </configurator>
  </extension>
</plugin>
