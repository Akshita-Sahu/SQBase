<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>

    <extension point="org.jkiss.sqbase.dataSourceView">
        <view
                id="org.jkiss.sqbase.ext.bigquery.dataSourceWizardView"
                targetID="org.jkiss.sqbase.ext.ui.newConnectionWizard"
                dataSource="bigquery"
                label="%bigquery.dialog.connection.header"
                class="org.jkiss.sqbase.ext.bigquery.ui.views.BigQueryConnectionPage"
                icon="platform:/plugin/org.jkiss.sqbase.ext.bigquery/icons/bigquery_icon.png">
        </view>
        <view
                class="org.jkiss.sqbase.ext.bigquery.ui.views.BigQueryConnectionPage"
                icon="platform:/plugin/org.jkiss.sqbase.ext.bigquery/icons/bigquery_icon.png"
                id="org.jkiss.sqbase.ext.bigquery.dataSourceEditorView"
                dataSource="bigquery"
                label="%bigquery.dialog.connection.header"
                targetID="org.jkiss.sqbase.ext.ui.editConnectionDialog">
        </view>
    </extension>

    <extension point="org.jkiss.sqbase.ui.propertyConfigurator">
        <propertyConfigurator class="org.jkiss.sqbase.ext.bigquery.auth.BigQueryAuthModel" uiClass="org.jkiss.sqbase.ext.bigquery.ui.config.BigQueryAuthConfigurator"/>
    </extension>

</plugin>
