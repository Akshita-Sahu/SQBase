<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>
<plugin>

    <extension point="org.eclipse.ui.commands">
        <category id="org.jkiss.sqbase.ext.oracle" name="Oracle" description="Oracle Commands"/>
        <command id="org.jkiss.sqbase.ext.oracle.code.compile" name="Compile" description="Compile" categoryId="org.jkiss.sqbase.ext.oracle"/>
        <command id="org.jkiss.sqbase.ext.oracle.code.package.navigate" name="Go to source code" description="Navigate to object source code" categoryId="org.jkiss.sqbase.ext.oracle"/>
        <command id="org.jkiss.sqbase.ext.oracle.job.run" name="Run" description="Run Job" categoryId="org.jkiss.sqbase.ext.oracle"/>
    </extension>

    <extension point="org.eclipse.ui.commandImages">
        <image commandId="org.jkiss.sqbase.ext.oracle.code.compile" icon="icons/compile.png"/>
        <image commandId="org.jkiss.sqbase.ext.oracle.job.run" icon="icons/run.png"/>
    </extension>

    <extension point="org.eclipse.ui.handlers">
        <handler commandId="org.jkiss.sqbase.ext.oracle.code.compile" class="org.jkiss.sqbase.ext.oracle.ui.actions.CompileHandler">
            <enabledWhen>
                <or>
                    <with variable="selection">
                        <count value="+"/>
                        <iterate operator="and">
                            <!-- Here and below we use double check - adapt + instanceof.
                                sing <adapt> with final (Oracle-specific) type will force plugin activation (since E4.6)
                                see https://bugs.eclipse.org/bugs/show_bug.cgi?id=485569
                            -->
                            <adapt type="org.jkiss.sqbase.model.struct.DBSObject">
                                <instanceof value="org.jkiss.sqbase.ext.oracle.model.source.OracleSourceObject"/>
                            </adapt>
                        </iterate>
                    </with>
                    <with variable="activePart">
                        <adapt type="org.jkiss.sqbase.model.struct.DBSObject">
                            <instanceof value="org.jkiss.sqbase.ext.oracle.model.source.OracleSourceObject"/>
                        </adapt>
                    </with>
                </or>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.ext.oracle.code.package.navigate" class="org.jkiss.sqbase.ext.oracle.ui.actions.PackageNavigateHandler">
            <enabledWhen>
                <with variable="selection">
                    <count value="+"/>
                    <iterate operator="and">
                        <adapt type="org.jkiss.sqbase.model.struct.DBSObject">
                            <instanceof value="org.jkiss.sqbase.ext.oracle.model.OracleProcedurePackaged"/>
                        </adapt>
                        <!--<adapt type="org.jkiss.sqbase.ext.oracle.model.OracleProcedurePackaged"/>-->
                    </iterate>
                </with>
            </enabledWhen>
        </handler>
        <handler commandId="org.jkiss.sqbase.ext.oracle.job.run" class="org.jkiss.sqbase.ext.oracle.ui.actions.JobRunHandler">
            <enabledWhen>
                <or>
                    <with variable="selection">
                        <count value="+"/>
                        <iterate operator="and">
                            <!-- Here and below we use double check - adapt + instanceof.
                                sing <adapt> with final (Oracle-specific) type will force plugin activation (since E4.6)
                                see https://bugs.eclipse.org/bugs/show_bug.cgi?id=485569
                            -->
                            <adapt type="org.jkiss.sqbase.model.struct.DBSObject">
                                <instanceof value="org.jkiss.sqbase.ext.oracle.model.OracleSchedulerJob"/>
                            </adapt>
                        </iterate>
                    </with>
                    <with variable="activePart">
                        <adapt type="org.jkiss.sqbase.model.struct.DBSObject">
                            <instanceof value="org.jkiss.sqbase.ext.oracle.model.OracleSchedulerJob"/>
                        </adapt>
                    </with>
                </or>
            </enabledWhen>
        </handler>
    </extension>

    <extension point="org.eclipse.ui.menus">
        <menuContribution allPopups="false" locationURI="popup:org.eclipse.ui.popup.any?after=navigator_additions_end">
            <command commandId="org.jkiss.sqbase.ext.oracle.code.compile">
                <visibleWhen checkEnabled="true"/>
            </command>
            <command commandId="org.jkiss.sqbase.ext.oracle.code.package.navigate">
                <visibleWhen checkEnabled="true"/>
            </command>
            <command commandId="org.jkiss.sqbase.ext.oracle.job.run">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
    </extension>

    <extension point="org.eclipse.ui.editors">
        <editor
                name="%editor.session_manager.name"
                icon="platform:/plugin/org.jkiss.sqbase.model/icons/tree/sessions.svg"
                class="org.jkiss.sqbase.ext.oracle.ui.editors.OracleSessionEditor"
                id="org.jkiss.sqbase.ext.oracle.ui.editors.OracleSessionEditor"
                contributorClass="org.jkiss.sqbase.ui.editors.EditorSearchActionsContributor">
        </editor>
        <editor
                name="%editor.session_manager.name"
                icon="platform:/plugin/org.jkiss.sqbase.model/icons/tree/locked.svg"
                class="org.jkiss.sqbase.ext.oracle.ui.editors.OracleLockEditor"
                id="org.jkiss.sqbase.ext.oracle.ui.editors.OracleLockEditor">
        </editor>
    </extension>

    <extension point="org.jkiss.sqbase.ui.propertyConfigurator">
        <propertyConfigurator class="org.jkiss.sqbase.ext.oracle.model.auth.OracleAuthModelDatabaseNative" uiClass="org.jkiss.sqbase.ext.oracle.ui.config.OracleAuthDatabaseNativeConfigurator"/>
        <propertyConfigurator class="org.jkiss.sqbase.ext.oracle.model.auth.OracleAuthOS" uiClass="org.jkiss.sqbase.ext.oracle.ui.config.OracleAuthOSConfigurator"/>
    </extension>

    <extension point="org.jkiss.sqbase.dataSourceProvider">
        <editorContribution editorId="org.jkiss.sqbase.ext.oracle.ui.editors.OracleSessionEditor" category="connectionEditor" label="%editor.session_manager.name" icon="platform:/plugin/org.jkiss.sqbase.model/icons/tree/sessions.svg">
            <supports dataSource="oracle"/>
        </editorContribution>
        <editorContribution editorId="org.jkiss.sqbase.ext.oracle.ui.editors.OracleLockEditor" category="connectionEditor" label="%editor.lock_manager.name" icon="#locked">
            <supports dataSource="oracle"/>
        </editorContribution>
    </extension>

    <extension point="org.eclipse.ui.preferencePages">
        <page category="org.jkiss.sqbase.preferences.drivers" id="org.jkiss.sqbase.preferences.oracle.general" class="org.jkiss.sqbase.ext.oracle.ui.views.PrefPageOracle" name="Oracle">
            <keywordReference id="org.jkiss.sqbase.core.keyword.sqbase"/>
        </page>
    </extension>

    <extension point="org.eclipse.ui.propertyPages">
        <page id="org.jkiss.sqbase.preferences.oracle.main" class="org.jkiss.sqbase.ext.oracle.ui.views.PrefPageOracle" name="%page.org.jkiss.sqbase.preferences.oracle.main.name">
            <enabledWhen>
                <adapt type="org.jkiss.sqbase.model.DBPDataSourceContainer">
                    <test property="org.jkiss.sqbase.core.datasourceContainer.driverId" value="oracle_thin"/>
                </adapt>
            </enabledWhen>
        </page>
    </extension>

    <extension point="org.eclipse.ui.importWizards">
        <wizard
                category="org.jkiss.sqbase.config.migration.third-party"
                class="org.jkiss.sqbase.ext.oracle.ui.tools.sqldeveloper.ConfigImportWizardSqlDeveloper"
                id="org.jkiss.sqbase.config.migration.sqldeveloper"
                name="Oracle SQL Developer"
                icon="icons/sqldeveloper.png">
            <description>Oracle SQL Developer</description>
        </wizard>
        <wizard
                category="org.jkiss.sqbase.config.migration.third-party"
                class="org.jkiss.sqbase.ext.oracle.ui.tools.toad.ConfigImportWizardToad"
                id="org.jkiss.sqbase.config.migration.toad"
                name="Toad"
                icon="icons/toad_icon.png">
            <description>Toad</description>
        </wizard>
    </extension>

    <extension point="org.jkiss.sqbase.dataSourceView">
        <view
                id="org.jkiss.sqbase.ext.oracle.dataSourceWizardView"
                dataSource="oracle"
                targetID="org.jkiss.sqbase.ext.ui.newConnectionWizard"
                label="%dialog.connection.header"
                class="org.jkiss.sqbase.ext.oracle.ui.views.OracleConnectionPage"
                icon="icons/oracle_icon.png">
        </view>
        <view
                id="org.jkiss.sqbase.ext.oracle.dataSourceEditorView"
                dataSource="oracle"
                targetID="org.jkiss.sqbase.ext.ui.editConnectionDialog"
                label="%dialog.connection.header"
                class="org.jkiss.sqbase.ext.oracle.ui.views.OracleConnectionPage">
        </view>
    </extension>

    <extension point="org.jkiss.sqbase.databaseEditor">
        <editor id="source.declaration" class="org.jkiss.sqbase.ext.oracle.ui.editors.OracleSourceDeclarationEditor"
                label="%editor.package.declaration.name" description="%editor.package.declaration.description" icon="#sql_text" position="additions_middle"
                contributor="org.jkiss.sqbase.ui.editors.sql.SQLEditorContributorNested" type="folder" embeddable="false">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleView"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleMaterializedView"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleProcedureStandalone"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OraclePackage"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleDataType" if="!object.predefined"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleTrigger"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleJavaClass"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleJob"/>
        </editor>
        <editor id="source.definition" class="org.jkiss.sqbase.ext.oracle.ui.editors.OracleSourceDefinitionEditor"
                label="%editor.package.body.name" description="%editor.package.body.description" icon="#sql_text" position="additions_middle"
                contributor="org.jkiss.sqbase.ui.editors.sql.SQLEditorContributorNested" type="folder" embeddable="false">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OraclePackage"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleDataType" if="!object.predefined"/>
        </editor>
        <editor id="schedulerJob.action" class="org.jkiss.sqbase.ext.oracle.ui.editors.SchedulerJobActionEditor"
                label="%editor.scheduler.job.action.name" description="%editor.scheduler.job.action.description" icon="#sql_text" position="additions_middle"
                contributor="org.jkiss.sqbase.ui.editors.sql.SQLEditorContributorNested" type="folder" embeddable="false">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleSchedulerJob"/>
        </editor>
        <editor id="source.ddl" class="org.jkiss.sqbase.ext.oracle.ui.editors.OracleObjectDDLEditor"
                label="DDL" description="DDL" icon="#sql_text" position="additions_middle"
                contributor="org.jkiss.sqbase.ui.editors.sql.SQLEditorContributorNested" type="folder">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleTable"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleSchedulerJob"/>
        </editor>
        <editor id="source.declaration.read-only" class="org.jkiss.sqbase.ext.oracle.ui.editors.OracleObjectDeclarationViewer"
                label="%editor.package.declaration.name" description="%editor.package.declaration.description" icon="#sql_text" position="additions_middle"
                contributor="org.jkiss.sqbase.ui.editors.sql.SQLEditorContributorNested" type="folder" embeddable="false">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleSchema"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleTableIndex"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleSequence"/>
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleTablespace"/>
        </editor>
        <editor
                id="org.jkiss.sqbase.ext.oracle.ui.editors.SchedulerJobLogEditor"
                class="org.jkiss.sqbase.ext.oracle.ui.editors.SchedulerJobLogEditor"
                objectType="org.jkiss.sqbase.ext.oracle.model.OracleSchedulerJob"
                main="false"
                label="%editor.scheduler.job.log.name"
                description="%editor.scheduler.job.log.description"
                position="additions_start"
                icon="icons/job_log.png">
        </editor>

        <configurator class="org.jkiss.sqbase.ext.oracle.ui.config.OracleConstraintConfigurator">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleTableConstraint"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.oracle.ui.config.OracleDataTypeConfigurator">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleDataType"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.oracle.ui.config.OracleForeignKeyConfigurator">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleTableForeignKey"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.oracle.ui.config.OracleIndexConfigurator">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleTableIndex"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.oracle.ui.config.OraclePackageConfigurator">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OraclePackage"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.oracle.ui.config.OracleProcedureConfigurator">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleProcedureStandalone"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.oracle.ui.config.OracleQueueConfigurator">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleQueue"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.oracle.ui.config.OracleSchemaConfigurator">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleSchema"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.oracle.ui.config.OracleSequenceConfigurator">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleSequence"/>
        </configurator>
        <configurator class="org.jkiss.sqbase.ext.oracle.ui.config.OracleTableTriggerConfigurator">
            <objectType name="org.jkiss.sqbase.ext.oracle.model.OracleTableTrigger"/>
        </configurator>

    </extension>

    <extension point="org.jkiss.sqbase.tools">
        <tools>
            <toolGroup id="org.jkiss.sqbase.ext.oracle.ui.tools.statistics" label="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.statistics.label"/>
            <toolGroup id="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance" label="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.label"/>
            <tool
                    description="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.OracleToolScript.description"
                    id="org.jkiss.sqbase.ext.oracle.ui.tools.OracleToolScript"
                    label="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.OracleToolScript.label">
                <task id="oracleScriptExecute"/>
            </tool>
            <tool
                    description="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolValidateStructure.label"
                    id="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolValidateStructure"
                    group="org.jkiss.sqbase.ext.oracle.ui.tools.statistics"
                    label="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolValidateStructure.label"
                    singleton="false">
                <task id="oracleToolValidateStructure"/>
            </tool>
            <tool
                    description="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolRefreshMView.label"
                    id="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolRefreshMView"
                    group="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance"
                    label="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolRefreshMView.label"
                    singleton="false">
                <task id="oracleToolMViewRefresh"/>
            </tool>
            <tool
                    description="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolGatherStatistics.label"
                    id="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolGatherStatistics"
                    group="org.jkiss.sqbase.ext.oracle.ui.tools.statistics"
                    label="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolGatherStatistics.label"
                    singleton="false">
                <task id="oracleToolTableGatherStatistics"/>
                <task id="oracleToolIndexGatherStatistics"/>
            </tool>
            <tool
                    description="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolTruncate.description"
                    id="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolTruncate"
                    group="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance"
                    label="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolTruncate.label"
                    singleton="false">
                <task id="oracleToolTableTruncate"/>
            </tool>
            <tool
                    description="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolTriggerDisable.description"
                    id="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolTriggerDisable"
                    group="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance"
                    label="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolTriggerDisable.label"
                    singleton="false">
                <task id="oracleToolTriggerDisable"/>
            </tool>
            <tool
                    description="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolTriggerEnable.description"
                    id="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolTriggerEnable"
                    group="org.jkiss.sqbase.ext.oracle.ui.tools.maintenance"
                    label="%tool.org.jkiss.sqbase.ext.oracle.ui.tools.maintenance.OracleToolTriggerEnable.label"
                    singleton="false">
                <task id="oracleToolTriggerEnable"/>
            </tool>
        </tools>
    </extension>
    <extension point="org.jkiss.sqbase.sql.executors">
        <executor class="org.jkiss.sqbase.ext.oracle.ui.tools.OracleScriptExecutor" datasource="oracle"/>
    </extension>
    <extension point="org.jkiss.sqbase.task.ui">
        <configurator type="oracleScriptExecute" class="org.jkiss.sqbase.ext.oracle.ui.tools.OracleTaskConfigurator"/>
    </extension>

    <extension point="org.eclipse.core.runtime.preferences">
        <initializer class="org.jkiss.sqbase.ext.oracle.ui.internal.OraclePreferencesInitializer"/>
    </extension>

</plugin>
