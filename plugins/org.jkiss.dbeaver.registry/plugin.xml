<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>
    <extension-point id="org.jkiss.sqbase.pluginService" name="%extension-point.org.jkiss.sqbase.pluginService.name" schema="schema/org.jkiss.sqbase.pluginService.exsd"/>

    <!-- Non UI extensions -->
    <extension-point id="org.jkiss.sqbase.objectManager" name="%extension-point.org.jkiss.sqbase.objectManager.name" schema="schema/org.jkiss.sqbase.objectManager.exsd"/>
    <extension-point id="org.jkiss.sqbase.mavenRepository" name="%extension-point.org.jkiss.sqbase.mavenRepository.name" schema="schema/org.jkiss.sqbase.mavenRepository.exsd"/>
    <extension-point id="org.jkiss.sqbase.dataSourceProvider" name="%extension-point.org.jkiss.sqbase.dataSourceProvider.name" schema="schema/org.jkiss.sqbase.dataSourceProvider.exsd"/>
    <extension-point id="org.jkiss.sqbase.dataSourceStorage" name="%extension-point.org.jkiss.sqbase.dataSourceStorage.name" schema="schema/org.jkiss.sqbase.dataSourceStorage.exsd"/>
    <extension-point id="org.jkiss.sqbase.dataSourceAuth" name="%extension-point.org.jkiss.sqbase.dataSourceAuth.name" schema="schema/org.jkiss.sqbase.dataSourceAuth.exsd"/>
    <extension-point id="org.jkiss.sqbase.dataSourceHandler" name="%extension-point.org.jkiss.sqbase.dataSourceHandler.name" schema="schema/org.jkiss.sqbase.dataSourceHandler.exsd"/>
    <extension-point id="org.jkiss.sqbase.driverManager" name="%extension-point.org.jkiss.sqbase.driverManager.name" schema="schema/org.jkiss.sqbase.driverManager.exsd"/>
    <extension-point id="org.jkiss.sqbase.resourceType" name="%extension-point.org.jkiss.sqbase.resourceType.name" schema="schema/org.jkiss.sqbase.resourceType.exsd"/>
    <extension-point id="org.jkiss.sqbase.networkHandler" name="%extension-point.org.jkiss.sqbase.networkHandler.name" schema="schema/org.jkiss.sqbase.networkHandler.exsd"/>
    <extension-point id="org.jkiss.sqbase.resources" name="%extension-point.org.jkiss.sqbase.resources.name" schema="schema/org.jkiss.sqbase.resources.exsd"/>
    <extension-point id="org.jkiss.sqbase.product.bundles" name="%extension-point.org.jkiss.sqbase.product.bundles.name" schema="schema/org.jkiss.sqbase.product.bundles.exsd"/>
    <extension-point id="org.jkiss.sqbase.language" name="%extension-point.org.jkiss.sqbase.language.name" schema="schema/org.jkiss.sqbase.language.exsd"/>
    <extension-point id="org.jkiss.sqbase.task" name="%extension-point.org.jkiss.sqbase.task.name" schema="schema/org.jkiss.sqbase.task.exsd"/>
    <extension-point id="org.jkiss.sqbase.productFeature" name="%extension-point.org.jkiss.sqbase.productFeature.name" schema="schema/org.jkiss.sqbase.productFeature.exsd"/>

    <!-- Language names should be written in their respective languages. Do not localize them -->
    <extension point="org.jkiss.sqbase.language">
        <language code="en" label="English"/>
        <language code="fr" label="Français"/>
        <language code="de" label="Deutsch"/>
        <language code="it" label="Italiano"/>
        <language code="ja" label="日本語"/>
        <language code="ko" label="한국어"/>
        <language code="pt_BR" label="Português (BR)"/>
        <language code="ro" label="Română"/>
        <language code="ru" label="Русский"/>
        <language code="zh" label="简体中文"/>
        <language code="es" label="Español"/>
        <language code="tw" label="繁體中文"/>
        <language code="uk" label="Українська"/>
        <language code="ar" label="العربية"/>
    </extension>

    <extension point="org.jkiss.sqbase.driverManager">
        <category id="sql" name="%driver.category.sql.name" description="%driver.category.sql.description" icon="#folder_database" rank="4" promoted="true"/>
        <category id="nosql" name="%driver.category.nosql.name" description="%driver.category.nosql.description" icon="#folder_database" rank="5" promoted="true"/>
        <category id="analytic" name="%driver.category.analytical.name" description="%driver.category.analytical.description" icon="#folder_database" rank="10" promoted="true"/>
        <category id="file" name="%driver.category.file.name" description="%driver.category.file.description" icon="#folder_database" rank="11" promoted="true"/>
        <category id="embedded" name="%driver.category.embedded.name" description="%driver.category.embedded.description" icon="#folder_database" rank="12" promoted="true"/>
        <category id="timeseries" name="%driver.category.timeseries.name" description="%driver.category.timeseries.description" icon="#folder_database" rank="15" promoted="true"/>
        <category id="hadoop" name="%driver.category.hadoop.name" description="%driver.category.hadoop.description" icon="#folder_database" rank="20" promoted="true"/>
        <category id="fulltext" name="%driver.category.fulltext.name" description="%driver.category.fulltext.description" icon="#folder_database" rank="22" promoted="true"/>
        <category id="graph" name="%driver.category.graph.name" description="%driver.category.graph.description" icon="#folder_database" rank="23" promoted="true"/>
    </extension>

    <extension point="org.jkiss.sqbase.networkHandler">
        <handler
            type="proxy"
            id="socks_proxy"
            codeName="Proxy"
            prefix="proxy"
            label="%handler.socks_proxy.label"
            description="%handler.socks_proxy.description"
            desktop="true"
            secured="true"
            order="3"
            handlerClass="org.jkiss.sqbase.model.impl.net.SocksProxyImpl"/>
    </extension>

    <extension point="org.jkiss.sqbase.dataSourceProvider">
        <datasourceOrigin id="local" label="Local configuration" class="org.jkiss.sqbase.registry.DataSourceOriginProviderLocal"/>
    </extension>

    <extension point="org.jkiss.sqbase.dataSourceAuth">
        <authModel
            id="native"
            label="Username/password"
            description="Database authentication (username/password)"
            class="org.jkiss.sqbase.model.impl.auth.AuthModelDatabaseNative"
            default="true">

            <propertyGroup label="Database user">
                <property id="user" label="User" type="string"/>
                <property id="password" label="Password" type="string" features="password"/>
            </propertyGroup>

        </authModel>
    </extension>

    <extension point="org.eclipse.core.contenttype.contentTypes">
        <content-type
                file-extensions="bm"
                id="org.jkiss.sqbase.bookmark"
                name="Database Bookmarks"
                priority="normal"
                describer="org.jkiss.sqbase.ui.resources.bookmarks.BookmarkContentTypeDescriber"/>

        <content-type file-extensions="lnk" id="org.jkiss.sqbase.shortcut" name="Windows shortcuts" priority="normal">
            <describer class="org.eclipse.core.runtime.content.BinarySignatureDescriber">
                <!-- http://msdn.microsoft.com/en-us/library/dd871305%28PROT.10%29.aspx -->
                <parameter name="signature" value="4C,00,00,00,01,14,02,00,00,00,00,00,C0,00,00,00,00,00,00,46"/>
                <parameter name="offset" value="0"/>
            </describer>
        </content-type>
    </extension>

    <extension point="org.jkiss.sqbase.resourceType">
        <type id="default"/>
    </extension>

    <extension point="org.jkiss.sqbase.mavenRepository">
        <repository id="maven-central" name="%maven.respository.central" url="https://repo1.maven.org/maven2/" order="0"/>
        <repository id="oss.sonatype.org" snapshot="true" name="%maven.repository.sonatype" url="https://oss.sonatype.org/content/repositories/snapshots/" order="0"/>

        <!-- Non-HTTPS Maven Central is no longer alive. Hooray. -->
        <!--
                <repository id="maven-central-unsecure" name="%maven.respository.central.unsecure" url="http://central.maven.org/maven2/" order="99999"/>
        -->
    </extension>

</plugin>
