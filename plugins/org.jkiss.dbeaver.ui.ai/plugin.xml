<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>

<plugin>
    <extension point="org.jkiss.sqbase.ui.propertyConfigurator">
        <propertyConfigurator class="org.jkiss.sqbase.model.ai.engine.openai.OpenAIEngine" uiClass="org.jkiss.sqbase.ui.ai.engine.openai.OpenAiConfigurator"/>
        <propertyConfigurator class="org.jkiss.sqbase.model.ai.engine.copilot.CopilotCompletionEngine" uiClass="org.jkiss.sqbase.ui.ai.engine.copilot.CopilotConfigurator"/>
    </extension>

    <extension point="org.eclipse.core.runtime.preferences">
        <initializer class="org.jkiss.sqbase.ui.ai.preferences.AIPreferencesInitializer"/>
    </extension>

    <extension point="org.eclipse.core.expressions.definitions">
        <definition id="org.jkiss.sqbase.ai.preferences">
            <instanceof value="org.jkiss.sqbase.model.ai.AISettings"/>
        </definition>
    </extension>

    <extension point="org.eclipse.ui.preferencePages">
        <page id="org.jkiss.sqbase.preferences.ai" class="org.jkiss.sqbase.ui.ai.preferences.AIPreferencePageMain" name="%pref.page.ai.main.name">
            <keywordReference id="org.jkiss.sqbase.core.keyword.sqbase"/>
            <keywordReference id="sqbase.ai.pref"/>
        </page>
        <page id="org.jkiss.sqbase.preferences.ai.engines" category="org.jkiss.sqbase.preferences.ai" class="org.jkiss.sqbase.ui.ai.preferences.AIPreferencePageEngines" name="%pref.page.ai.engines.name">
            <keywordReference id="org.jkiss.sqbase.core.keyword.sqbase"/>
            <keywordReference id="sqbase.ai.pref"/>
        </page>
        <page id="org.jkiss.sqbase.preferences.ai.config" category="org.jkiss.sqbase.preferences.ai" class="org.jkiss.sqbase.ui.ai.preferences.AIPreferencePageConfiguration" name="%pref.page.ai.config.name">
            <keywordReference id="org.jkiss.sqbase.core.keyword.sqbase"/>
            <keywordReference id="sqbase.ai.pref"/>
            <keywordReference id="sqbase.ai.config"/>
        </page>
        <page id="org.jkiss.sqbase.preferences.ai.prompts" category="org.jkiss.sqbase.preferences.ai" class="org.jkiss.sqbase.ui.ai.preferences.AIPreferencePagePrompts" name="%pref.page.ai.prompts.name">
            <keywordReference id="org.jkiss.sqbase.core.keyword.sqbase"/>
            <keywordReference id="sqbase.ai.pref"/>
            <keywordReference id="sqbase.ai.prompts"/>
        </page>
    </extension>
    <extension point="org.eclipse.ui.propertyPages">
        <page id="org.jkiss.sqbase.preferences.ai.engines" class="org.jkiss.sqbase.ui.ai.preferences.AIPreferencePageEngines" name="%pref.page.ai.engines.name">
            <enabledWhen><reference definitionId="org.jkiss.sqbase.ai.preferences"/></enabledWhen>
        </page>
        <page id="org.jkiss.sqbase.preferences.ai.config" class="org.jkiss.sqbase.ui.ai.preferences.AIPreferencePageConfiguration" name="%prop.page.ai.config.name">
            <enabledWhen><reference definitionId="org.jkiss.sqbase.ai.preferences"/></enabledWhen>
        </page>
        <page id="org.jkiss.sqbase.preferences.ai.prompts" class="org.jkiss.sqbase.ui.ai.preferences.AIPreferencePagePrompts" name="%pref.page.ai.prompts.name">
            <enabledWhen><reference definitionId="org.jkiss.sqbase.ai.preferences"/></enabledWhen>
        </page>
    </extension>

    <extension point="org.eclipse.core.expressions.propertyTesters">
        <propertyTester class="org.jkiss.sqbase.ui.ai.AIPropertyTester"
                        id="org.jkiss.sqbase.ui.ai.AIPropertyTester"
                        namespace="org.jkiss.sqbase.ui.ai"
                        properties="isDisabled"
                        type="java.lang.Object"/>
    </extension>

    <extension point="org.eclipse.ui.commands">
        <command id="org.jkiss.sqbase.ui.ai.showCompletion" name="%command.org.jkiss.sqbase.ui.ai.showCompletion.name" description="%command.org.jkiss.sqbase.ui.ai.showCompletion.description" categoryId="org.jkiss.sqbase.core.sql"/>
        <command id="org.jkiss.sqbase.ui.ai.configuration" name="%command.org.jkiss.sqbase.ui.ai.configuration.name" description="%command.org.jkiss.sqbase.ui.ai.configuration.description" categoryId="org.jkiss.sqbase.core.sql"/>
    </extension>

    <extension point="org.eclipse.ui.menus">
        <menuContribution allPopups="false" locationURI="menu:SQLEditorMenu?after=query">
            <command commandId="org.jkiss.sqbase.ui.ai.showCompletion">
                <visibleWhen checkEnabled="true"/>
            </command>
        </menuContribution>
        <menuContribution allPopups="false" locationURI="toolbar:org.jkiss.sqbase.ui.editors.sql.toolbar.side.top?after=tools" >
            <command commandId="org.jkiss.sqbase.ui.ai.showCompletion">
                <visibleWhen>
                    <and>
                        <reference definitionId="org.jkiss.sqbase.core.ai.completion.enabled.by.user"/>
                        <reference definitionId="org.jkiss.sqbase.core.ai.completion.enabled.by.policy"/>
                        <test property="org.jkiss.sqbase.ui.toolbar.configuration.visible" args="sqlEditor.side.top,org.jkiss.sqbase.ui.ai.showCompletion"/>
                    </and>
                </visibleWhen>
            </command>
        </menuContribution>
    </extension>

    <extension point="org.eclipse.core.expressions.definitions">
        <!-- Enabled by the user -->
        <definition id="org.jkiss.sqbase.core.ai.completion.enabled.by.user">
            <not>
                <test property="org.jkiss.sqbase.ui.ai.isDisabled" forcePluginActivation="true" />
            </not>
        </definition>
    </extension>

    <extension point="org.eclipse.ui.activities">
        <activity id="sqbase.ai.activity.policy" name="AI Activity (Policy)">
            <enabledWhen>
                <reference definitionId="org.jkiss.sqbase.core.ai.completion.enabled.by.policy"/>
            </enabledWhen>
        </activity>
        <activity id="sqbase.ai.activity" name="AI Activity">
            <enabledWhen>
                <and>
                    <reference definitionId="org.jkiss.sqbase.core.ai.completion.enabled.by.user"/>
                    <reference definitionId="org.jkiss.sqbase.core.ai.completion.enabled.by.policy"/>
                </and>
            </enabledWhen>
        </activity>

        <activityPatternBinding activityId="sqbase.ai.activity.policy" pattern="org.jkiss.sqbase.ui.ai.*"/>
        <activityPatternBinding activityId="sqbase.ai.activity.policy" pattern="org.jkiss.sqbase.preferences.ai"/>
    </extension>

    <extension point="org.eclipse.ui.commandImages">
        <image commandId="org.jkiss.sqbase.ui.ai.showCompletion" icon="platform:/plugin/org.jkiss.sqbase.model.ai/icons/ai.svg"/>
    </extension>
    <extension point="org.eclipse.ui.handlers">
        <handler commandId="org.jkiss.sqbase.ui.ai.showCompletion" class="org.jkiss.sqbase.ui.ai.internal.AITranslateHandler"/>
        <handler commandId="org.jkiss.sqbase.ui.ai.configuration" class="org.jkiss.sqbase.ui.ai.internal.AIConfigurationHandler"/>
    </extension>

    <extension point="org.eclipse.ui.bindings">
        <key commandId="org.jkiss.sqbase.ui.ai.showCompletion" contextId="org.eclipse.ui.contexts.window" schemeId="org.eclipse.ui.defaultAcceleratorConfiguration" sequence="CTRL+I"/>
    </extension>


    <extension point="org.jkiss.sqbase.toolBarConfiguration">
        <toolBar key="sqlEditor.side.top">
            <item commandId="org.jkiss.sqbase.ui.ai.showCompletion" defaultVisibility="true"/>
        </toolBar>
    </extension>

    <extension point="org.eclipse.ui.keywords">
        <keyword id="sqbase.ai.pref" label="%keyword.org.jkiss.sqbase.ai.pref"/>
        <keyword id="sqbase.ai.config" label="%keyword.org.jkiss.sqbase.ai.config"/>
        <keyword id="sqbase.ai.prompts" label="%keyword.org.jkiss.sqbase.ai.prompts"/>
    </extension>
    <extension point="org.jkiss.sqbase.workbenchHandler">
        <workbenchWindowInitializer class="org.jkiss.sqbase.ui.ai.AIWorkbenchInitializer" order="2"/>
    </extension>
</plugin>
