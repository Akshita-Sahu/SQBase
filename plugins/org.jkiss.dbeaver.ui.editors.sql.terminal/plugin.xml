<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
    <extension point="org.jkiss.sqbase.sql.editorAddIns">
        <addIn id="org.jkiss.sqbase.ui.editors.sql.terminal.editorAddIn" class="org.jkiss.sqbase.ui.editors.sql.terminal.SQLTerminalEditorAddIn"/>
    </extension>

    <extension point="org.eclipse.ui.commands">
        <command id="org.jkiss.sqbase.ui.editors.sql.show.terminalView" name="%command.org.jkiss.sqbase.ui.editors.sql.show.terminalView.name" description="%command.org.jkiss.sqbase.ui.editors.sql.show.terminalView.description" categoryId="org.jkiss.sqbase.core.sql">
            <state class="org.eclipse.jface.commands.ToggleState" id="org.eclipse.ui.commands.toggleState" />
        </command>
    </extension>

    <extension point="org.eclipse.ui.handlers">
        <handler commandId="org.jkiss.sqbase.ui.editors.sql.show.terminalView" class="org.jkiss.sqbase.ui.editors.sql.terminal.SQLTerminalViewSwitchHandler">
            <enabledWhen><reference definitionId="org.jkiss.sqbase.core.ui.sql.editor"/></enabledWhen>
        </handler>
    </extension>
    
    <extension point="org.eclipse.ui.menus">
        <menuContribution allPopups="false" locationURI="toolbar:org.jkiss.sqbase.ui.editors.sql.toolbar.side.top?after=tools" >
            <command commandId="org.jkiss.sqbase.ui.editors.sql.show.terminalView">
                <visibleWhen checkEnabled="false">
                    <test property="org.jkiss.sqbase.ui.toolbar.configuration.visible" args="sqlEditor.side.top,org.jkiss.sqbase.ui.editors.sql.show.terminalView"/>
                </visibleWhen>
            </command>
        </menuContribution>
        <menuContribution allPopups="false" locationURI="popup:org.jkiss.sqbase.ui.editors.sql.SQLEditor.execute?after=plan">
            <command commandId="org.jkiss.sqbase.ui.editors.sql.show.terminalView"/>
        </menuContribution >
    </extension>
    
    <extension point="org.jkiss.sqbase.toolBarConfiguration">
        <toolBar key="sqlEditor.side.top">
            <item commandId="org.jkiss.sqbase.ui.editors.sql.show.terminalView" defaultVisibility="true"/>
        </toolBar>
    </extension>
    
    <extension point="org.eclipse.ui.commandImages">
    	<image commandId="org.jkiss.sqbase.ui.editors.sql.show.terminalView" icon="platform:/plugin/org.jkiss.sqbase.ui/icons/sql/sql_console.svg" />
    </extension>

    <extension point="org.eclipse.core.runtime.preferences">
        <initializer class="org.jkiss.sqbase.ui.editors.sql.terminal.internal.SQLTerminalPreferencesInitializer"/>
    </extension>

    <extension point="org.eclipse.ui.propertyPages">
        <page category="org.jkiss.sqbase.preferences.main.sqleditor" class="org.jkiss.sqbase.ui.editors.sql.terminal.SQLTerminalPreferencesPage" id="org.jkiss.sqbase.preferences.main.sqleditor.terminalview" name="%terminal_view_item_text">
            <enabledWhen><reference definitionId="org.jkiss.sqbase.core.preferences.datasource" /></enabledWhen>
        </page>
    </extension>

    <extension point="org.eclipse.ui.preferencePages">
        <page category="org.jkiss.sqbase.preferences.main.sqleditor" class="org.jkiss.sqbase.ui.editors.sql.terminal.SQLTerminalPreferencesPage" id="org.jkiss.sqbase.preferences.main.sql.terminalview" name="%terminal_view_item_text" />
    </extension>

</plugin>
