<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.2"?>

<plugin>

    <extension point="org.jkiss.sqbase.dataSourceView">
        <view
                id="org.jkiss.sqbase.ext.hana.dataSourceWizardView"
                targetID="org.jkiss.sqbase.ext.ui.newConnectionWizard"
                dataSource="hana"
                label="%hana.dialog.connection.header"
                class="org.jkiss.sqbase.ext.hana.ui.views.HANAConnectionPage"
                icon="icons/sap_hana_icon.png">
        </view>
        <view
                class="org.jkiss.sqbase.ext.hana.ui.views.HANAConnectionPage"
                icon="icons/sap_hana_icon.png"
                id="org.jkiss.sqbase.ext.hana.dataSourceEditorView"
                dataSource="hana"
                label="%hana.dialog.connection.header"
                targetID="org.jkiss.sqbase.ext.ui.editConnectionDialog">
        </view>
    </extension>

    <extension point="org.jkiss.sqbase.databaseEditor">
        <configurator class="org.jkiss.sqbase.ext.hana.ui.config.HANASchemaConfigurator">
            <objectType name="org.jkiss.sqbase.ext.hana.model.HANASchema"/>
        </configurator>
    </extension>

</plugin>
