<?xml version="1.0" encoding="UTF-8"?>
<feature
      id="org.jkiss.sqbase.git.feature"
      label="SQBase Git support"
      version="1.0.165.qualifier"
      provider-name="SQBase Corp">

   <copyright>SQBase Corp and others</copyright>
   <license url="https://sqbase.io/product/sqbase_license.txt"/>

   <requires>
      <import feature="org.jkiss.sqbase.ui.feature" version="0.0.0" match="greaterOrEqual"/>
   </requires>

   <includes id="org.eclipse.jgit" version="0.0.0"/>
   <includes id="org.eclipse.jgit.gpg.bc" version="0.0.0"/>
   <includes id="org.eclipse.jgit.http.apache" version="0.0.0"/>
   <includes id="org.eclipse.jgit.ssh.apache" version="0.0.0"/>
   <includes id="org.eclipse.egit" version="0.0.0"/>

   <!-- SSH Agent provider -->
   <plugin id="org.apache.sshd.osgi" version="0.0.0"/>
   <plugin id="org.apache.sshd.sftp" version="0.0.0"/>

   <!-- SQBase deps -->
   <plugin id="org.jkiss.sqbase.team.git.ui" version="0.0.0"/>

</feature>
